[NEAT]
fitness_criterion     = max
fitness_threshold     = 100000
pop_size              = 50
reset_on_extinction   = False
no_fitness_termination = False

[DefaultGenome]
# Node activation options
activation_default      = tanh
feed_forward            = True
activation_mutate_rate  = 0.1
activation_options      = tanh sigmoid relu

# Structural mutation options
# Config ISOLADO do executor nativo (Fase 2, protocolo v3 EGOCENTRICO).
# NASCER MAGRO (NEAT canonico, Stanley 2002): num_hidden=0 e densidade baixa. A criatura
# nasce quase pelada; o MUNDO (selecao) constroi a estrutura sob demanda via node_add/conn_add.
# So cresce o que se paga -> sem erosao a discutir (nada e adicionado a toa). densidade 0.1 com
# 0 ocultos da ~113 conexoes DIRETAS input->output de largada: reativo o bastante pra nao nascer
# pedra (o marca-passo ja chega a alguma saida), longe do teto de 741 que era semeadura imposta.
# Cold-start atenuado por ambiente (marca-passo + FERTILITY_PCT mais gentil no mundo), nao por
# semear cerebro rico. NOTA: comentarios ASCII puro (parser cp1252 quebra com acento).
single_structural_mutation = False
structural_mutation_surer  = default
initial_connection         = partial_direct 0.1

# Node aggregation options
aggregation_default     = sum
aggregation_mutate_rate = 0.0
aggregation_options     = sum

# Node bias options
bias_init_type          = gaussian
bias_init_mean          = 0.0
bias_init_stdev         = 0.1
bias_max_value          = 10.0
bias_min_value          = -10.0
bias_mutate_power       = 0.5
bias_mutate_rate        = 0.7
bias_replace_rate       = 0.1

# Genome compatibility options
compatibility_disjoint_coefficient = 1.0
compatibility_weight_coefficient   = 0.5

# Connection add/remove rates
# ADD-ONLY (par natural do nascer magro): delecao = 0. Com nascer magro, a complexidade CRESCE
# da estaca zero conforme a selecao premia; deletar so brigaria com esse crescimento. A poda e
# responsabilidade da MORTE do genoma (selecao pura), nao do operador. Sem cascata, sem erosao.
conn_add_prob           = 0.4
conn_delete_prob        = 0.0

# Node response options
# response ESCALA a soma antes do tanh: out = tanh(bias + response*Σ(w*x)). A saturacao (41%)
# vem da SOMA de ~85 conexoes (peso medio so 2.3), nao de pesos gigantes -> cap de peso quase nao
# ajuda. Baixar response de 1.0 pra 0.5 encolhe a soma e des-satura (medido: response=0.3 -> 29%).
# Efeito gradual (afeta nos novos; os legados guardam response=1.0). Substrato, nao vies.
response_init_type      = gaussian
response_init_mean      = 0.5
response_init_stdev     = 0.0
response_max_value      = 30.0
response_min_value      = -30.0
response_mutate_power   = 0.0
response_mutate_rate    = 0.0
response_replace_rate   = 0.0

# Connection enable options
enabled_default         = True
enabled_mutate_rate     = 0.01
enabled_rate_to_true_add = 0.0
enabled_rate_to_false_add = 0.0

# Connection weight options
# ANTI-SATURACAO (parte 2, secundaria): a saturacao (41% das saidas no talo) vem da SOMA de ~85
# conexoes, nao de pesos gigantes (peso medio so 2.3) -> o cap (30->8) quase nao muda (medido:
# 41->40%). O que ajuda AQUI e a forca de mutacao 1.2->0.6: pesos driftam mais devagar -> a longo
# prazo o peso medio fica menor -> menos saturacao. O lever principal e o response (ver acima).
weight_init_type        = gaussian
weight_init_mean        = 0.0
weight_init_stdev       = 1.0
weight_max_value        = 8
weight_min_value        = -8
weight_mutate_power     = 0.6
weight_mutate_rate      = 0.9
weight_replace_rate     = 0.1

# Node add/remove rates
# node_delete=0: matar a cascata (apagar um oculto levava dezenas de ligacoes de uma vez) foi o
# driver #1 da erosao medida (741->~230 em 5h, deriva do operador, nao escolha do mundo). Com
# nascer magro + add-only, ocultos SO surgem quando node_add divide uma conexao que a selecao
# manteve -> profundidade/nao-linearidade cresce sob demanda, do jeito canonico do NEAT.
node_add_prob           = 0.2
node_delete_prob        = 0.0

# Network parameters
# v3.1 EGOCENTRICO: 161 entradas = bias + energy + stomach + endorfina + MARCA-PASSO(sin,cos)
# + 5 canais x 31 (cone de visao pra frente). 7 saidas (frente, tras, vira-esq, vira-dir,
# fica, ataca-frente, EMPURRA-frente). Trocar num_inputs/outputs exige RESET.
# num_hidden=0: NASCER MAGRO -- sem camada oculta semeada; a profundidade emerge por node_add
# sob selecao (NEAT canonico). Era 8 (semeadura imposta); ver Structural mutation options.
num_hidden              = 0
num_inputs              = 161
num_outputs             = 7

[DefaultSpeciesSet]
compatibility_threshold = 4.0

[DefaultStagnation]
species_fitness_func = max
max_stagnation       = 20
species_elitism      = 0

[DefaultReproduction]
elitism            = 2
survival_threshold = 0.2
min_species_size   = 1
